# PostgreSQL Database connection URL (NeonDB Serverless)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# JWT Secret Key for token signing
JWT_SECRET="YOUR_JWT_SECRET_KEY"

# Google Gemini API Key for AI Assistant chatbot functionality
VITE_GEMINI_KEY="YOUR_GEMINI_API_KEY"

# Cloudinary credentials for product image uploads
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"

# Google OAuth Client ID for login integration
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

